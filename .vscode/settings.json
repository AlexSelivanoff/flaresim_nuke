{
  // Force the Microsoft C/C++ extension to handle IntelliSense.
  // Without this, the clangd extension (if installed) silently takes over
  // and ignores c_cpp_properties.json, causing "undeclared identifier 'DD'".
  "C_Cpp.intelliSenseEngine": "default",
  "C_Cpp.default.configurationProvider": "",

  // If you have the clangd extension installed, this disables it for this
  // workspace so the two providers don't conflict.
  "clangd.enabled": false
}
